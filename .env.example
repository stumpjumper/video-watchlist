# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Required for AI summary generation (https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional — path to directory containing server.crt and server.key
# If set, HTTPS is enabled on HTTPS_PORT (default 443)
# CERT_DIR=/path/to/certs

# Optional — defaults to 4000 (HTTP) and 443 (HTTPS)
# PORT=4000
# HTTPS_PORT=443
